{
  "name": "@focusgrid/kcl-dom",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewcyuan/focusgrid.git",
    "directory": "packages/kcl-dom"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --config ../../tsdown.config.mjs --format esm,cjs --deps.never-bundle @focusgrid/kcl --deps.never-bundle @focusgrid/shortcut-engine",
    "test": "vitest run --config ../../vitest.config.ts --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@focusgrid/kcl": "workspace:*",
    "@focusgrid/shortcut-engine": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
