{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@focusgrid/shortcut-engine": ["packages/shortcut-engine/src/index.ts"],
      "@focusgrid/core": ["packages/focusgrid-core/src/index.ts"],
      "@focusgrid/dom": ["packages/focusgrid-dom/src/index.ts"],
      "@focusgrid/react": ["packages/focusgrid-react/src/index.tsx"],
      "@focusgrid/kcl": ["packages/kcl-core/src/index.ts"],
      "@focusgrid/kcl-dom": ["packages/kcl-dom/src/index.ts"],
      "@focusgrid/kcl-react": ["packages/kcl-react/src/index.tsx"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true
  }
}
