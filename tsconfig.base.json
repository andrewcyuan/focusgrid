{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@focusgrid/shortcut-engine": ["packages/shortcut-engine/src/index.ts"],
      "@focusgrid/core": ["packages/focusgrid-core/src/index.ts"],
      "@focusgrid/dom": ["packages/focusgrid-dom/src/index.ts"],
      "@focusgrid/react": ["packages/focusgrid-react/src/index.tsx"],
      "@focusgrid/kcc-core": ["packages/kcc-core/src/index.ts"],
      "@focusgrid/kcc-dom": ["packages/kcc-dom/src/index.ts"],
      "@focusgrid/kcc-react": ["packages/kcc-react/src/index.tsx"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true
  }
}
